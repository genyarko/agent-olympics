# Google Cloud / Gemini Config
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Tavily Search API
TAVILY_API_KEY=your-tavily-key

# App Config
DOMAIN=boardroom.your-domain.com
ALLOWED_ORIGINS=http://localhost:3000,https://boardroom.your-domain.com

DATABASE_URL=postgresql://boardroom:boardroom_password@postgres:5432/boardroom
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=boardroom-logs
